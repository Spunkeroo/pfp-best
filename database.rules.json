{
  "rules": {
    "pfpbest": {
      "pfps": {
        ".read": true,
        "$pfpId": {
          ".write": "!data.exists()",
          ".validate": "newData.hasChildren(['id','imageUrl','title','category','uploadedAt','uploadedBy']) && newData.child('title').val().length <= 80 && newData.child('category').val().length <= 30",
          "ratingSum": {
            ".write": "data.parent().exists()"
          },
          "ratingCount": {
            ".write": "data.parent().exists()"
          },
          "ratingAvg": {
            ".write": "data.parent().exists()"
          },
          "upvotes": {
            ".write": "data.parent().exists()"
          },
          "downvotes": {
            ".write": "data.parent().exists()"
          },
          "commentCount": {
            ".write": "data.parent().exists()"
          },
          "score": {
            ".write": "data.parent().exists()"
          }
        }
      },
      "ratings": {
        ".read": false,
        "$ratingKey": {
          ".write": "newData.hasChildren(['pfpId','rating','fp','timestamp']) && newData.child('rating').isNumber() && newData.child('rating').val() >= 1 && newData.child('rating').val() <= 10",
          ".read": false
        }
      },
      "comments": {
        ".read": true,
        "$pfpId": {
          "$commentId": {
            ".write": "!data.exists() && newData.hasChildren(['id','pfpId','text','fp','timestamp']) && newData.child('text').val().length <= 280",
            ".read": true
          }
        }
      },
      "votes": {
        ".read": false,
        "$voteKey": {
          ".write": "newData.val() === 'up' || newData.val() === 'down'",
          ".read": false
        }
      },
      "banned": {
        ".read": false,
        "$fp": {
          ".read": true,
          ".write": "newData.hasChildren(['reason','fp','banned_at'])"
        }
      },
      "stats": {
        ".read": true,
        ".write": true
      }
    },
    "ads_manager": {
      "ads": {
        ".read": true,
        ".write": false
      },
      "global_stats": {
        ".read": true,
        ".write": false
      }
    }
  }
}
